ENV=development

# --- Database ---
# Local Postgres example; for AWS RDS append ?sslmode=require
DATABASE_URL=postgresql+psycopg://connectx:connectx@localhost:5432/connectx
AUTO_CREATE_TABLES=true

# --- Auth ---
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Async / cache ---
REDIS_URL=redis://localhost:6379/0

# --- Email / invites ---
# Local dev: a console SMTP (e.g. MailHog/mailpit on 1025) needs no auth.
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_STARTTLS=true,
#        SMTP_USER=<address>, SMTP_PASSWORD=<16-char app password>.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=false
EMAIL_FROM=alumni@rooman.com
INVITE_TOKEN_EXPIRE_HOURS=168

# --- Frontend ---
FRONTEND_BASE_URL=http://localhost:5173
